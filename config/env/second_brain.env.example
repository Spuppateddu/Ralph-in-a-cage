# Template for the Laravel `second_brain` repo's throwaway verify env.
# Copy to `second_brain.env` (gitignored) and fill in real-but-disposable values.
# The runner overwrites DB_* to point at the cage `db` service and runs
# key:generate, so you mainly need the app-specific config that the app requires
# at boot (e.g. VAPID for web-push).

APP_NAME="Second Brain"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack

# Overwritten by the runner to the cage db; shown here for clarity.
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=second_brain
DB_USERNAME=sb
DB_PASSWORD=secret

# Disposable drivers so verify needs no external services.
CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=log

# Web push — REQUIRED at boot. Generate a throwaway pair:
#   php -r "require 'vendor/autoload.php'; print_r(Minishlink\WebPush\VAPID::createVapidKeys());"
VAPID_SUBJECT=mailto:bot@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
