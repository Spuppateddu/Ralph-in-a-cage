# Template for a Convex (Next.js) repo's throwaway verify env.
# Copy to `<repo-name>.env` (the clone basename without .git), e.g. `my-frontend.env`.
# The runner copies this to `<repo>/.env.local` before `npm run build`.
#
# Optional — if you omit it, the runner injects a placeholder NEXT_PUBLIC_CONVEX_URL
# so the build can complete without a live Convex deployment.

# A real-but-disposable Convex URL is fine; the build never contacts it.
NEXT_PUBLIC_CONVEX_URL=https://placeholder.convex.cloud

# If the frontend calls a Laravel backend at build time, point it somewhere inert.
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:8000
