# Template for a Laravel repo's throwaway verify env.
# Copy to `<repo-name>.env` (the clone basename without .git), e.g. `my-backend.env`.
# The runner overwrites DB_* to point at the cage MySQL (this project's
# DB_DATABASE) and runs key:generate, so you mainly need the app-specific config
# the app requires at boot.

APP_NAME="My Project"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack

# Overwritten by the runner to the cage db; shown here for clarity.
DB_CONNECTION=mysql

# Disposable drivers so verify needs no external services.
CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=log
