# ============================================================================
# Per-project config. Copy this whole `example` directory to
# `config/projects/<your-project>/`, then copy this file to `project.env`
# (gitignored) and fill it in. One directory per project; each gets its own
# runner container and its own /workspace.
#
# Values here OVERRIDE the machine-global `.env` for this project (the runner
# loads `.env` first, then this file).
# ============================================================================

# Base URL of this project's DEPLOYED task-API backend, no trailing slash.
# For a backend running on THIS host during testing, use:
#   http://host.docker.internal:8000
PROJECT_API_BASE_URL=https://api.your-project.example

# The project's slug + bot token from your task API
# (project page -> Bot API -> Generate token; set the project to "In progress").
PROJECT_SLUG=
PROJECT_TOKEN=

# Which agent does the work for this project: claude | codex
DEFAULT_AGENT=claude

# Branch the bot pulls from and targets PRs at, for THIS project's repos.
# Never pushed to directly. (e.g. second-brain uses `master`, many repos use `main`.)
BASE_BRANCH=main

# MySQL schema used to verify this project's Laravel repos. MUST be unique per
# project so projects never share a database. The runner creates it on demand
# (CREATE DATABASE IF NOT EXISTS), so no manual db setup is needed.
DB_DATABASE=your_project
