# Secrets / per-machine config — never commit.
.env
config/repos.list
config/projects.list

# Generated by scripts/gen-compose.sh (one runner service per project).
docker-compose.generated.yml

# Per-project config: each config/projects/<name>/ holds that project's
# project.env, repos.list, and env/ overlays — all per-machine secrets. Only the
# committed `example` project template (and any *.example / README) is tracked.
config/projects/*/project.env
config/projects/*/repos.list
config/projects/*/env/*
!config/projects/*/env/*.example
!config/projects/*/env/README.md
!config/projects/example/**

# Legacy single-project layout (pre per-project dirs). Still gitignored.
config/env/*
!config/env/*.example
!config/env/README.md

# Per-machine custom image setup (the committed template is custom-setup.example.sh).
custom-setup.sh

# Local logs if ever written here.
*.log

# Extra local env files (the committed template is .env.example).
.env.local
.env.*.local

# Defensive: never commit keys accidentally dropped in this folder
# (the real SSH key lives in a Docker volume, not here).
*.pem
id_ed25519
id_ed25519.pub
id_rsa
id_rsa.pub

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
