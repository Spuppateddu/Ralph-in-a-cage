# ============================================================================
# Ralph runner MACHINE-GLOBAL config. Copy to `.env` and fill in. `.env` is
# gitignored. Per-PROJECT settings (slug, token, API URL, agent, base branch,
# db schema) live in config/projects/<name>/project.env instead — copy the
# committed config/projects/example/ directory to start a new project.
# Agent logins and the SSH key are NOT here — they live in volumes set up by
# scripts/setup.sh.
# ============================================================================

# ---- Isolation -------------------------------------------------------------
# How projects share infrastructure (db + agent logins + SSH key):
#   shared   = one MySQL container (a schema per project) + shared claude/codex/
#              ssh volumes. Log in / add the SSH key ONCE for all projects.
#   detached = each project gets its own db container and its own credential
#              volumes. Full isolation; log in once PER project.
# Either way every project always gets its own runner container + workspace.
ISOLATION_MODE=shared

# ---- Scheduling (applies to every project's runner) ------------------------
# How often to check for tasks, in minutes (default 5).
CHECK_INTERVAL_MINUTES=5
# For schedules cron can express but minutes can't (e.g. hourly), set a full
# cron expression here instead — it overrides CHECK_INTERVAL_MINUTES.
# CRON_SCHEDULE=0 * * * *

# How many tasks to work per check. 1 (default) = finish one task before the next
# check can start another; 0 = drain all available tasks each check. A new task
# never starts while one is still being worked, regardless of this value.
MAX_TASKS_PER_PASS=1

# ---- Git / GitHub ----------------------------------------------------------
# Commit identity for the bot.
GIT_AUTHOR_NAME=Ralph Bot
GIT_AUTHOR_EMAIL=ralph-bot@users.noreply.github.com

# GitHub token with `repo` scope — used ONLY to open PRs (git push uses the SSH
# key from setup.sh).
GH_TOKEN=

# ---- Database (shared MySQL server for Laravel verification) ----------------
# Host/creds for the cage MySQL. The per-project SCHEMA is set by each project's
# DB_DATABASE (in project.env); the runner creates it on demand.
DB_HOST=db
DB_PORT=3306
DB_USERNAME=sb
DB_PASSWORD=secret

# Max seconds an agent may run on one task.
CLAUDE_TIMEOUT=1800
