# ============================================================================
# Ralph runner config. Copy to `.env` and fill in. `.env` is gitignored.
# Agent logins and the SSH key are NOT here — they live in volumes set up by
# scripts/setup.sh.
# ============================================================================

# ---- Second Brain bot API --------------------------------------------------
# Base URL of your DEPLOYED backend, no trailing slash. Inserted by hand.
# For a backend running on THIS host during testing, use:
#   http://host.docker.internal:8000
PROJECT_API_BASE_URL=https://api.your-second-brain.example

# The project the bot works on (its slug + bot token from the Second Brain UI:
# project page -> Bot API -> Generate token; set the project to "In progress").
PROJECT_SLUG=
PROJECT_TOKEN=

# Which agent does the work by default: claude | codex
DEFAULT_AGENT=claude

# (Optional) Work on several projects instead: leave PROJECT_SLUG/PROJECT_TOKEN
# empty and create config/projects.list with "slug token [agent]" per line.

# ---- Git / GitHub ----------------------------------------------------------
# Branch the bot pulls from and targets PRs at. Never pushed to directly.
BASE_BRANCH=master

# Commit identity for the bot.
GIT_AUTHOR_NAME=Ralph Bot
GIT_AUTHOR_EMAIL=ralph-bot@users.noreply.github.com

# GitHub token with `repo` scope — used ONLY to open PRs (git push uses the SSH
# key from setup.sh).
GH_TOKEN=

# ---- Database (used to verify Laravel changes) -----------------------------
# Match the bundled `db` service; defaults are fine.
DB_HOST=db
DB_PORT=3306
DB_DATABASE=second_brain
DB_USERNAME=sb
DB_PASSWORD=secret

# Max seconds an agent may run on one task.
CLAUDE_TIMEOUT=1800
